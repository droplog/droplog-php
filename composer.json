{
  "name": "droplog/droplog",
  "description": "Official PHP SDK for Droplog — audit log infrastructure for SaaS",
  "type": "library",
  "license": "MIT",
  "keywords": ["droplog", "audit-log", "audit", "logging", "saas", "compliance"],
  "authors": [
    {
      "name": "Droplog",
      "email": "support@droplog.dev"
    }
  ],
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Droplog\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Droplog\\Tests\\": "tests/"
    }
  },
  "homepage": "https://droplog.dev"
}
